# ─────────────────────────────────────────────────────────────
# 环境变量样例 —— 复制为 .env 后填入真实值。
# .env 不进版本库(见 .gitignore)。生产密钥务必覆盖默认值。
# ─────────────────────────────────────────────────────────────

# 运行环境:development | production
APP_ENV=development

# ── 数据库(M1 起用;M0 容器已就绪)────────────────────────
POSTGRES_USER=agent
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=agent
# 应用连接串(compose 内网用服务名 postgres;本机直连用 127.0.0.1)
DATABASE_URL=postgresql+psycopg://agent:change-me-in-prod@postgres:5432/agent

# ── Redis(M4/M5 起用;M0 容器已就绪)──────────────────────
REDIS_URL=redis://redis:6379/0

# ── 管理端鉴权 ─────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-prod
# 签 token 的密钥,务必设为长随机串(留空则每次重启失效所有 token)
ADMIN_SECRET=
ADMIN_TOKEN_TTL=43200

# ── LLM / Embedding(M3 起用,国内 DashScope)──────────────
DASHSCOPE_API_KEY=

# ── 存储后端切换(M1)─────────────────────────────────────
# true=运行态(会话/运行记录/长期记忆)走 PostgreSQL;false(默认)=JSON 文件
USE_DB_STORES=false

# ── 用户端 API 鉴权(P0)──────────────────────────────────
# 默认 true:所有 /api/* 需登录,写操作按角色权限。仅排障时可临时设 false。
USER_API_AUTH=true

# ── 日志 ───────────────────────────────────────────────────
LOG_LEVEL=INFO
# true=JSON 结构化(生产);false=彩色控制台(开发)
LOG_JSON=false

# ── CORS(逗号分隔;生产收窄到实际域名)────────────────────
CORS_ORIGINS=*

# ── Grafana ────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
