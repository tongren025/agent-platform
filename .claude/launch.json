{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--host", "127.0.0.1", "--port", "5188"],
      "cwd": "web",
      "port": 5188,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--host", "127.0.0.1", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "admin",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "admin.main:app", "--host", "127.0.0.1", "--port", "8001", "--reload"],
      "port": 8001
    }
  ]
}
