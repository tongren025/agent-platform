# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
dist/
build/

# Node / Frontend
web/node_modules/
web/dist/

# Runtime data (JSON file store, user-generated)
data/

# C# build artifacts (legacy)
src/*/bin/
src/*/obj/

# IDE
.vs/
.vscode/
.idea/
*.suo
*.user

# OS
Thumbs.db
.DS_Store

# Sensitive config (contains API keys)
appsettings.Development.json
.env

# Grafana runtime data
deploy/grafana/data/

# Logs & temp output
*.log
_server*
_ssr_*
output/

# Local resource files
resouce/

# Built frontend assets (regenerated by npm run build)
wwwroot/assets/

# CodeGraph local index cache
.codegraph/
